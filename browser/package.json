{
  "name": "browser",
  "version": "0.0.1",
  "description": "Obstor Browser",
  "license": "Apache-2.0",
  "scripts": {
    "test": "jest",
    "dev": "NODE_ENV=dev webpack-dev-server --devtool cheap-module-eval-source-map --progress --colors --hot --content-base dev",
    "build": "NODE_ENV=dev node build.js",
    "release": "NODE_ENV=production node build.js",
    "format": "prettier --write 'app/**/*.js'"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "./app/js/jest/setup.js"
    ],
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "https://localhost:8080"
    },
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/app/js/jest/__mocks__/fileMock.js",
      "\\.(css|scss)$": "identity-obj-proxy"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-object-rest-spread": "^7.28.6",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "async": "^3.2.6",
    "babel-jest": "^30.2.0",
    "babel-loader": "^10.1.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.8",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "json-loader": "^0.5.7",
    "less": "^4.5.1",
    "less-loader": "^12.3.1",
    "prettier": "^3.8.1",
    "purgecss-webpack-plugin": "^8.0.0",
    "style-loader": "^4.0.0",
    "url-loader": "^4.1.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bootstrap": "^5.3.8",
    "classnames": "^2.5.1",
    "core-js": "^3.48.0",
    "expect": "^30.2.0",
    "glob-all": "^3.3.1",
    "history": "^5.3.0",
    "humanize": "0.0.9",
    "identity-obj-proxy": "^3.0.0",
    "jwt-decode": "^4.0.0",
    "local-storage-fallback": "^5.0.0",
    "material-design-iconic-font": "^2.2.0",
    "mime-db": "^1.54.0",
    "mime-types": "^3.0.2",
    "moment": "^2.30.1",
    "path-browserify": "^1.0.1",
    "query-string": "^9.3.1",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-copy-to-clipboard": "^5.1.0",
    "react-custom-scrollbars": "^4.2.1",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-infinite-scroller": "^1.2.6",
    "react-onclickout": "^2.0.8",
    "react-qr-code": "^2.0.18",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "redux": "^5.0.1",
    "redux-mock-store": "^1.5.5",
    "redux-thunk": "^3.1.0",
    "reselect": "^5.1.1",
    "superagent": "^10.3.0",
    "superagent-es6-promise": "^1.0.0",
    "webpack": "^5.105.4"
  },
  "pnpm": {
    "overrides": {
      "cheerio": "1.0.0-rc.12"
    }
  }
}